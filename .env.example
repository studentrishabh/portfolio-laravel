##############################################################
# PORTFOLIO ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets!
##############################################################

# ── APP SETTINGS ─────────────────────────────────────────────
APP_NAME="Rishabh Portfolio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── LOGGING ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── DATABASE ─────────────────────────────────────────────────
# Change these to match your MySQL credentials
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio_db
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ── CACHE & SESSION ──────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── MAIL (optional, for sending reply emails) ────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=rishabh.chaurasiya011@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="rishabh.chaurasiya011@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── PRODUCTION OVERRIDES ─────────────────────────────────────
# On live server, change these:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com
